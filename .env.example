# =============================================================================
# AI NEXUS — Environment Configuration
# =============================================================================
# Copy this file: cp .env.example .env
# NEVER commit .env files — they are in .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# SECURITY: Generate a strong random secret (min 32 characters)
# Command: openssl rand -base64 32
JWT_SECRET=<generate-very-long-random-secret-min-32-chars>

# ---------------------------------------------------------------------------
# Database (SQLite for local dev)
# ---------------------------------------------------------------------------
DATABASE_URL=file:./data/ai-nexus.db

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
ENABLE_LLM=false
ENABLE_IMAGE_GEN=false
ENABLE_MUSIC=false
ENABLE_VOICE=false

# ---------------------------------------------------------------------------
# Production note:
# - Use Docker secrets, HashiCorp Vault, or GitHub Secrets in production
# - Rotate secrets regularly
# - Never use these placeholder values in production
